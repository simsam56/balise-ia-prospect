generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Company {
  id                          String    @id @default(uuid())
  nom                         String
  pays                        String    @default("France")
  region                      String
  ville                       String
  codePostal                  String
  siren                       String?
  secteurActivite             String
  tailleEffectif              String
  caEstime                    String
  siteWeb                     String
  lienLinkedinEntreprise      String
  indicateurDataMaturity      Int       @default(0)
  notes                       String    @default("")
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
  contacts                    Contact[]

  @@index([region, ville])
  @@index([secteurActivite])
  @@index([nom])
}

model Contact {
  id               String        @id @default(uuid())
  entrepriseId     String
  entreprise       Company       @relation(fields: [entrepriseId], references: [id], onDelete: Cascade)
  nom              String
  prenom           String
  poste            String
  niveauDecision   String
  emailPro         String
  linkedinProfil   String
  telephone        String?
  languePrincipale String        @default("fr")
  notes            String        @default("")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  lead             Lead?

  @@index([entrepriseId])
  @@index([nom, prenom])
  @@index([emailPro])
}

model Lead {
  id               String      @id @default(uuid())
  contactId        String      @unique
  contact          Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  scoreEntreprise  Int         @default(0)
  scoreContact     Int         @default(0)
  scoreGlobal      Int         @default(0)
  priorite         String      @default("C")
  statutLead       String      @default("nouveau")
  notes            String      @default("")
  lastScoredAt     DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  activities       Activity[]
  sequenceEnrollments SequenceEnrollment[]
  emailLogs        EmailLog[]

  @@index([scoreGlobal, priorite])
  @@index([statutLead])
}

model Activity {
  id          String   @id @default(uuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  titre       String
  description String   @default("")
  type        String
  statut      String   @default("a_faire")
  dueDate     DateTime
  autoRuleKey String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([leadId, dueDate])
  @@index([statut, dueDate])
  @@index([autoRuleKey])
}

model SequenceEnrollment {
  id           String   @id @default(uuid())
  leadId        String
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  sequenceId    String
  currentStep   Int      @default(0)
  startDate     DateTime
  nextSendDate  DateTime
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([leadId, status])
  @@index([sequenceId, status])
  @@index([nextSendDate, status])
}

model EmailLog {
  id         String   @id @default(uuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  subject     String
  body        String   @default("")
  provider    String
  status      String
  messageId   String?
  sentAt      DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([leadId, sentAt])
  @@index([status, sentAt])
}
